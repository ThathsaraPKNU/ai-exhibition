<!DOCTYPE html>
<html lang="si">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Google AI Object Detector</title>
    <script src="https://cdn.jsdelivr.net/npm/@tensorflow/tfjs"></script>
    <script src="https://cdn.jsdelivr.net/npm/@tensorflow-models/coco-ssd"></script>
    <style>
        body { margin: 0; background: #000; color: #00f2ff; font-family: sans-serif; text-align: center; }
        #video-container { position: relative; width: 100%; max-width: 500px; margin: auto; }
        video, canvas { position: absolute; left: 0; top: 0; width: 100%; border-radius: 15px; }
        .status { margin-top: 380px; padding: 20px; font-size: 20px; font-weight: bold; }
    </style>
</head>
<body>

    <h2>Google AI භාණ්ඩ හඳුනාගැනීම</h2>
    
    <div id="video-container">
        <video id="webcam" autoplay playsinline muted></video>
        <canvas id="overlay"></canvas>
    </div>

    <div class="status" id="label">පද්ධතිය සූදානම් වෙමින් පවතී...</div>

    <script>
        const video = document.getElementById('webcam');
        const canvas = document.getElementById('overlay');
        const ctx = canvas.getContext('2d');
        const label = document.getElementById('label');

        const translations = {
            'cell phone': 'ජංගම දුරකථනය 📱',
            'bottle': 'බෝතලය 🍼',
            'person': 'පුද්ගලයා 👤',
            'backpack': 'බෑගය 🎒',
            'cup': 'කෝප්පය ☕',
            'laptop': 'ලැප්ටොප් එක 💻'
        };

        // කැමරාව පණගැන්වීම
        navigator.mediaDevices.getUserMedia({ video: true }).then(stream => {
            video.srcObject = stream;
            video.onloadedmetadata = () => {
                canvas.width = video.videoWidth;
                canvas.height = video.videoHeight;
                loadGoogleModel();
            };
        });

        async function loadGoogleModel() {
            // Google Pre-trained Model එක Load කිරීම
            const model = await cocoSsd.load();
            label.innerText = "භාණ්ඩයක් පෙන්වන්න...";
            
            predict(model);
        }

        async function predict(model) {
            const predictions = await model.detect(video);
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            predictions.forEach(p => {
                if (p.score > 0.6) {
                    ctx.strokeStyle = "#00f2ff";
                    ctx.lineWidth = 4;
                    ctx.strokeRect(p.bbox[0], p.bbox[1], p.bbox[2], p.bbox[3]);
                    
                    const sinhalaName = translations[p.class] || p.class;
                    label.innerText = sinhalaName;
                }
            });

            requestAnimationFrame(() => predict(model));
        }
    </script>
</body>
</html>
